---
import Layout from "../layouts/Layout.astro";
import Icon from "../components/Icon.astro";

const strengths = [
  {
    icon: "wifi-off" as const,
    title: "Works anywhere",
    body: "Patient data is stored locally on the device. No internet connection required to use the app day-to-day.",
  },
  {
    icon: "download" as const,
    title: "Install and go",
    body: "Mein Scope installs like an app, directly from the browser — no app store, no IT deployment project.",
  },
  {
    icon: "users" as const,
    title: "Role-based access",
    body: "Admins manage users and review the audit log; clinicians work in patient records.",
  },
  {
    icon: "shield" as const,
    title: "Full audit log",
    body: "Every login, record edit, and backup is logged — so you always know who did what and when.",
  },
  {
    icon: "rotate-ccw" as const,
    title: "Your data, your control",
    body: "Back up and restore a full data snapshot manually, whenever you choose — export it, keep it, move it.",
  },
  {
    icon: "layout" as const,
    title: "Comfortable either way",
    body: "Light and dark themes, with a responsive layout that works from a side navigation panel.",
  },
];
---

<Layout
  title="Mein Scope — Offline-First Endoscopy & Colonoscopy Records"
  description="Purpose-built PWA for endoscopy and colonoscopy intake, capture, and reporting. Works fully offline, installs in seconds, no IT required."
>
  <!-- Hero -->
  <section class="mx-auto max-w-4xl px-6 pt-20 pb-16 text-center sm:pt-28">
    <span class="eyebrow">
      <Icon name="wifi-off" class="size-4 text-brand-600" />
      Offline-first, purpose-built
    </span>

    <h1 class="mt-7 text-4xl font-heading tracking-[-0.03em] text-balance text-ink-950 sm:text-6xl">
      Endoscopy records that don't need the internet to work.
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-lg text-ink-500 text-balance">
      Mein Scope handles patient intake, photo and video capture, and PDF reporting — all from one
      app that keeps working through outages, dead zones, and everything in between.
    </p>

    <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
      <a href="/contact" class="btn-primary">
        Request a Demo
        <Icon name="arrow-right" class="size-4" />
      </a>
      <a href="#how-it-works" class="btn-secondary">See How It Works</a>
    </div>
  </section>

  <div class="flex flex-col items-center" aria-hidden="true">
    <span class="h-10 border-l border-dashed border-ink-300/40"></span>
    <span class="flex size-8 shrink-0 items-center justify-center rounded-[10px] bg-paper-0 text-brand-600 shadow-[0_2px_4px_0_rgba(32,31,39,0.06),0_0_0_1px_rgba(32,31,39,0.07)]">
      <Icon name="wifi-off" class="size-4" />
    </span>
    <span class="h-10 border-l border-dashed border-ink-300/40"></span>
  </div>

  <!-- App preview placeholder -->
  <section class="mx-auto max-w-5xl px-6 pb-24">
    <div class="card overflow-hidden !p-0">
      <div class="flex items-center gap-1.5 border-b border-paper-200 bg-paper-50 px-4 py-3">
        <span class="size-2.5 rounded-full bg-paper-200"></span>
        <span class="size-2.5 rounded-full bg-paper-200"></span>
        <span class="size-2.5 rounded-full bg-paper-200"></span>
        <span class="ml-3 text-xs text-ink-300">Mein Scope — Patient Record</span>
      </div>
      <div
        class="flex aspect-16/8 items-center justify-center bg-gradient-to-br from-brand-50 to-paper-50"
      >
        <div class="flex flex-col items-center gap-3 text-ink-300">
          <Icon name="clipboard" class="size-10" />
          <p class="text-sm">App preview — swap in a real product screenshot</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem framing -->
  <section class="border-t border-paper-200 bg-paper-0">
    <div class="mx-auto max-w-3xl px-6 py-24 text-center">
      <span class="eyebrow">
        <Icon name="wifi-off" class="size-4 text-brand-600" />
        The problem
      </span>
      <h2 class="mt-4 text-3xl font-heading tracking-[-0.03em] text-ink-950 sm:text-4xl">
        Built for clinics the internet doesn't always reach
      </h2>
      <p class="mt-6 text-balance leading-relaxed text-ink-500">
        Most clinical software assumes a constant connection. In a lot of clinics, that assumption
        doesn't hold — a dropped connection mid-procedure shouldn't mean lost patient data, and
        waiting on IT to deploy new software shouldn't be the cost of digitizing your intake.
      </p>
      <p class="mt-4 text-balance leading-relaxed text-ink-500">
        Mein Scope was built the other way around: offline-first, install-and-go, with no server
        dependency for day-to-day use. It's designed specifically for endoscopy and colonoscopy
        workflows, not stretched from a general-purpose EHR.
      </p>
    </div>
  </section>

  <!-- How it works -->
  <section id="how-it-works" class="mx-auto max-w-6xl px-6 py-24">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow">
        <Icon name="clipboard" class="size-4 text-brand-600" />
        How it works
      </span>
      <h2 class="mt-4 text-3xl font-heading tracking-[-0.03em] text-ink-950 sm:text-4xl">
        One app, from intake to report
      </h2>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      <div class="card">
        <div class="flex size-10 items-center justify-center rounded-xl bg-brand-50 text-brand-600">
          <Icon name="clipboard" class="size-5" />
        </div>
        <div class="mt-5 text-sm font-semibold text-brand-600">Step 1</div>
        <h3 class="mt-1 text-lg font-heading tracking-[-0.015em] text-ink-950">Intake</h3>
        <p class="mt-2 text-sm leading-relaxed text-ink-500">
          Capture patient details before the procedure starts: demographics, DOB, procedure type
          and date, physician, findings and diagnosis fields — with validation built in, so
          nothing critical gets skipped.
        </p>
      </div>

      <div class="card">
        <div class="flex size-10 items-center justify-center rounded-xl bg-brand-50 text-brand-600">
          <Icon name="video" class="size-5" />
        </div>
        <div class="mt-5 text-sm font-semibold text-brand-600">Step 2</div>
        <h3 class="mt-1 text-lg font-heading tracking-[-0.015em] text-ink-950">Capture</h3>
        <p class="mt-2 text-sm leading-relaxed text-ink-500">
          Take photos and record video directly into the patient's record during the procedure. No
          separate camera roll to manage, no manual matching of files to patients afterward.
        </p>
      </div>

      <div class="card">
        <div class="flex size-10 items-center justify-center rounded-xl bg-brand-50 text-brand-600">
          <Icon name="file-text" class="size-5" />
        </div>
        <div class="mt-5 text-sm font-semibold text-brand-600">Step 3</div>
        <h3 class="mt-1 text-lg font-heading tracking-[-0.015em] text-ink-950">Report</h3>
        <p class="mt-2 text-sm leading-relaxed text-ink-500">
          Generate a PDF report for the patient in one click, formatted with your clinic's
          letterhead — ready to print, save, or hand over.
        </p>
      </div>
    </div>
  </section>

  <!-- Built for real clinics -->
  <section class="px-[30px] py-20 sm:py-24">
    <div class="relative mx-auto max-w-[100rem] overflow-hidden rounded-[2rem] bg-gradient-to-r from-brand-600 to-brand-500 py-20 sm:py-24">
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(60%_50%_at_85%_0%,rgba(255,255,255,0.16),transparent_70%)]"
      >
      </div>

      <div class="relative mx-auto max-w-6xl px-6">
        <div class="mx-auto max-w-2xl text-center">
          <span class="inline-flex items-center gap-1.5 rounded-[10px] bg-white/10 px-3 py-1.5 text-sm font-medium text-white ring-1 ring-white/20 backdrop-blur-sm">
            <Icon name="shield" class="size-4" />
            Built for real clinics
          </span>
          <h2 class="mt-4 text-4xl font-heading tracking-[-0.03em] text-white sm:text-5xl">
            The details that matter once you're actually using it
          </h2>
        </div>

        <div class="relative mt-14 border-t border-white/15">
          <span class="absolute left-1/2 top-0 flex size-8 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-[10px] bg-white text-brand-600 shadow-[0_4px_10px_rgba(15,50,80,0.25)]">
            <Icon name="check-circle" class="size-4" />
          </span>
        </div>

        <div class="relative mt-10 grid sm:grid-cols-2 lg:grid-cols-3">
          {
            strengths.map((s, i) => (
              <div
                class:list={[
                  "flex flex-col gap-3 px-4 py-8 sm:px-8",
                  i % 2 !== 0 && "sm:border-l sm:border-white/15",
                  i % 3 !== 0 && "lg:border-l lg:border-white/15",
                  i === 3 && "lg:border-l-0",
                  i >= 2 && "sm:border-t sm:border-white/15",
                  i >= 3 && "lg:border-t lg:border-white/15",
                  i === 2 && "lg:border-t-0",
                ]}
              >
                <div class="flex size-11 shrink-0 items-center justify-center rounded-xl bg-white/12 text-white">
                  <Icon name={s.icon} class="size-5" />
                </div>
                <div>
                  <h3 class="text-lg font-heading tracking-[-0.015em] text-white">{s.title}</h3>
                  <p class="mt-1.5 text-[15px] leading-relaxed text-white/75">{s.body}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="mx-auto max-w-5xl px-6 py-24">
    <div
      class="rounded-3xl bg-gradient-to-br from-ink-950 to-ink-700 px-8 py-16 text-center sm:px-16"
    >
      <h2 class="text-3xl font-heading tracking-[-0.03em] text-white sm:text-4xl">
        See Mein Scope on your own device
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-balance text-paper-200/80">
        The best way to evaluate Mein Scope is to watch it run through an actual intake, capture,
        and report cycle — including with the network off.
      </p>
      <a href="/contact" class="btn-primary mt-8">
        Request a Demo
        <Icon name="arrow-right" class="size-4" />
      </a>
    </div>
  </section>
</Layout>

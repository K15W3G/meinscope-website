---
import LogoFull from "../assets/logo/logo-full.svg";
---

<header class="sticky top-0 z-50 border-b border-paper-200 bg-paper-50/80 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center">
      <img src={LogoFull.src} alt="Mein Scope" class="h-7 w-auto" />
    </a>

    <nav class="hidden items-center gap-8 text-sm font-medium text-ink-500 md:flex">
      <a href="/features" class="transition-colors hover:text-ink-900">Features</a>
      <a href="/pricing" class="transition-colors hover:text-ink-900">Pricing</a>
      <a href="/about" class="transition-colors hover:text-ink-900">About</a>
      <a href="/faq" class="transition-colors hover:text-ink-900">FAQ</a>
    </nav>

    <a href="/contact" class="btn-primary">Request a Demo</a>
  </div>
</header>

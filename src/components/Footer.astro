---
import LogoFull from "../assets/logo/logo-full.svg";
---

<footer class="border-t border-paper-200">
  <div class="mx-auto max-w-6xl px-6 py-14">
    <div class="flex flex-col justify-between gap-10 md:flex-row">
      <div class="max-w-xs">
        <img src={LogoFull.src} alt="Mein Scope" class="h-9 w-auto" />
        <p class="mt-4 text-sm leading-relaxed text-ink-500">
          Offline-first intake, capture, and reporting for endoscopy and colonoscopy. Built in Uganda.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-10 sm:grid-cols-3">
        <div>
          <div class="text-xs font-semibold uppercase tracking-wide text-ink-300">Product</div>
          <ul class="mt-3 space-y-2 text-sm text-ink-500">
            <li><a href="/features" class="transition-colors hover:text-ink-900">Features</a></li>
            <li><a href="/pricing" class="transition-colors hover:text-ink-900">Pricing</a></li>
          </ul>
        </div>
        <div>
          <div class="text-xs font-semibold uppercase tracking-wide text-ink-300">Company</div>
          <ul class="mt-3 space-y-2 text-sm text-ink-500">
            <li><a href="/about" class="transition-colors hover:text-ink-900">About</a></li>
            <li><a href="/faq" class="transition-colors hover:text-ink-900">FAQ</a></li>
          </ul>
        </div>
        <div>
          <div class="text-xs font-semibold uppercase tracking-wide text-ink-300">Get in touch</div>
          <ul class="mt-3 space-y-2 text-sm text-ink-500">
            <li><a href="/contact" class="transition-colors hover:text-ink-900">Request a Demo</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-12 border-t border-paper-200 pt-6 text-center text-xs text-ink-300">
      <p>&copy; {new Date().getFullYear()} Mein Scope. All rights reserved.</p>
    </div>
  </div>
</footer>
